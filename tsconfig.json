{
	"compilerOptions": {
		"strict": true,
		"esModuleInterop": true,
		"noEmit": true,
		"target": "ES2022",
		"moduleResolution": "node",
		"resolveJsonModule": true,
		"experimentalDecorators": true,
		"skipLibCheck": true,
		"paths": {
			"bungie-api-ts/*": ["./src/node_modules/bungie-api-ts/*"],
			"@deepsight.gg/Enums": ["./task/manifest/Enums"],
			"@deepsight.gg/Interfaces": ["./task/manifest/Interfaces"]
		}
	},
	"include": [
		"**/*.ts",
		"**/*.mts"
	]
}
